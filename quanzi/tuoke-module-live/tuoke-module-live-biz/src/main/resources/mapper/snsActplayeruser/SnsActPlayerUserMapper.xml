<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.metast.tuoke.module.live.dal.mysql.snsActplayeruser.SnsActPlayerUserMapper">

    <!--
        一般情况下，尽可能使用 Mapper 进行 CRUD 增删改查即可。
        无法满足的场景，例如说多表关联查询，才使用 XML 编写 SQL。
        代码生成器暂时只生成 Mapper XML 文件本身，更多推荐 MybatisX 快速开发插件来生成查询。
        文档可见：https://www.iocoder.cn/MyBatis/x-plugins/
     -->
    <resultMap type="cn.metast.tuoke.module.live.controller.admin.snsActplayeruser.vo.SnsActPlayerUserRespVO" id="SnsActPlayerUserResult">
        <result property="id"    column="id"    />
        <result property="actId"    column="act_id"    />
        <result property="userId"    column="user_id"    />
        <result property="fieldValue"    column="field_value"    />
        <result property="actUserId"    column="act_user_id"    />
        <result property="title"    column="title"    />
    </resultMap>

    <sql id="selectSnsActPlayerUserVo">
        select id, act_id, user_id, field_value, act_user_id from sns_act_player_user
    </sql>
    <select id="selectSnsActPlayerUserList" parameterType="cn.metast.tuoke.module.live.controller.admin.snsActplayeruser.vo.SnsActPlayerUserRespVO" resultMap="SnsActPlayerUserResult">
        select t1.id, t1.act_id, t1.user_id, t1.field_value, t1.act_user_id,t3.title from sns_act_player_user t1
        left JOIN sns_act t2 on t1.act_id=t2.act_id LEFT JOIN  sns_post t3 on t2.post_id=t3.post_id
        <where>
            <if test="actId != null "> and t1.act_id = #{actId}</if>
            <if test="userId != null "> and t1.user_id = #{userId}</if>
            <if test="fieldValue != null  and fieldValue != ''"> and t1.field_value = #{fieldValue}</if>
            <if test="actUserId != null "> and t1.act_user_id = #{actUserId}</if>
        </where>
    </select>
    <!--批量插入报名信息-->
    <insert id="insertSnsActPlayerUserList" parameterType="java.util.List"
            useGeneratedKeys="true" keyProperty="id">
        insert into sns_act_player_user(act_id,user_id,field_value,act_user_id)
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (#{item.actId}, #{item.userId},#{item.fieldValue},#{item.actUserId})
        </foreach>
    </insert>
</mapper>
