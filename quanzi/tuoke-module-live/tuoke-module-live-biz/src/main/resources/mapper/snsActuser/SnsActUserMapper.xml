            <if test="orderNo != null">order_no,</if>
            <if test="feeTime != null">fee_time,</if>
            <if test="sName != null">s_name,</if>
            <if test="sPhone != null">s_phone,</if>
            <if test="sAge != null">s_age,</if>
            <if test="sGender != null">s_gender,</if>
            <if test="sUnit != null">s_unit,</if>
            <if test="sWx != null">s_wx,</if>
            <if test="sEmail != null">s_email,</if>

            <if test="planArriveTime != null">plan_arrive_time,</if>
            <if test="registerTime != null">register_time,</if>

            <if test="mileage != null">mileage,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="actId != null">#{actId},</if>
            <if test="planFee != null">#{planFee},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="status != null">#{status},</if>
            <if test="realFee != null">#{realFee},</if>
            <if test="orderNo != null">#{orderNo},</if>
            <if test="feeTime != null">#{feeTime},</if>
            <if test="sName != null">#{sName},</if>
            <if test="sPhone != null">#{sPhone},</if>
            <if test="sAge != null">#{sAge},</if>
            <if test="sGender != null">#{sGender},</if>
            <if test="sUnit != null">#{sUnit},</if>
            <if test="sWx != null">#{sWx},</if>
