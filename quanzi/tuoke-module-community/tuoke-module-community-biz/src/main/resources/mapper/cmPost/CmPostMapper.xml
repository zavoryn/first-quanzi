<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.metast.tuoke.module.community.dal.mysql.cmPost.CmPostMapper">

    <!--
        一般情况下，尽可能使用 Mapper 进行 CRUD 增删改查即可。
        无法满足的场景，例如说多表关联查询，才使用 XML 编写 SQL。
        代码生成器暂时只生成 Mapper XML 文件本身，更多推荐 MybatisX 快速开发插件来生成查询。
        文档可见：https://www.metast.cn/MyBatis/x-plugins/
     -->
    <resultMap type="cn.metast.tuoke.module.community.dal.dataobject.cmPost.CmPostDO" id="CmPostResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="topicId"    column="topic_id"    />
        <result property="discussId"    column="discuss_id"    />
        <result property="voteId"    column="vote_id"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="media"    column="media"    />
        <result property="pics"    column="pics"    />
        <result property="readCount"    column="read_count"    />
        <result property="likeCount"    column="like_count"    />
        <result property="commentCount"    column="comment_count"    />
        <result property="collectCount"    column="collect_count"    />
        <result property="postTop"    column="post_top"    />
        <result property="type"    column="type"    />
        <result property="address"    column="address"    />
        <result property="longitude"    column="longitude"    />
        <result property="latitude"    column="latitude"    />
        <result property="status"    column="status"    />
        <result property="sendTime"    column="send_time"    />
        <result property="remark"    column="remark"    />
        <result property="cateId"    column="cate_id"    />
        <result property="creator"    column="creator"    />
        <result property="createTime"    column="create_time"    />
        <result property="updater"    column="updater"    />
        <result property="updateTime"    column="update_time"    />

        <result property="topicName"    column="topic_name"    />
        <result property="realName"    column="real_name"    />
        <result property="certificateNo"    column="certificate_no"    />
    </resultMap>

    <sql id="cmPostVo">
       select t1.id,t1.user_id,t1.topic_id,t1.discuss_id,t1.vote_id,t1.title, t1.content, t1.media, t1.pics, t1.read_count, t1.like_count, t1.comment_count,t1.collect_count,
       t1.post_top, t1.type, t1.address, t1.longitude, t1.latitude, t1.status, t1.send_time,
       t1.remark,t1.cate_id,t1.creator,t1.create_time,t1.updater,t1.update_time,
       t2.topic_name,t2.real_name,t2.certificate_no
        from cm_post t1 left join cm_topic t2 on t1.topic_id = t2.id
    </sql>
    <select id="getCmPostPageNew" parameterType="cn.metast.tuoke.module.community.controller.admin.cmPost.vo.CmPostPageReqVO" resultMap="CmPostResult">
        <include refid="cmPostVo"/>
        where t1.deleted=0
            <if test="reqvo.userId != null"> and t1.user_id = #{reqvo.userId}</if>
            <if test="reqvo.topicId != null"> and t1.topic_id = #{reqvo.topicId}</if>
            <if test="reqvo.postTop != null"> and t1.post_top = #{reqvo.postTop}</if>
            <if test="reqvo.status != null"> and t1.status = #{reqvo.status}</if>
            <if test="reqvo.keyWord != null  and reqvo.keyWord != ''"> and t1.content like concat('%', #{reqvo.keyWord}, '%')</if>
            <if test="reqvo.beginTime != null  and reqvo.finishTime != null">
                AND DATE(t1.start_time) BETWEEN #{reqvo.beginTime} AND #{reqvo.finishTime}
            </if>
        order by t1.create_time DESC
    </select>

    <select id="getCmPostPageTop" parameterType="cn.metast.tuoke.module.community.controller.admin.cmPost.vo.CmPostPageReqVO" resultMap="CmPostResult">
        <include refid="cmPostVo"/>
        where t1.deleted=0
        <if test="reqvo.userId != null"> and t1.user_id = #{reqvo.userId}</if>
        <if test="reqvo.topicId != null"> and t1.topic_id = #{reqvo.topicId}</if>
        <if test="reqvo.postTop != null"> and t1.post_top = #{reqvo.postTop}</if>
        <if test="reqvo.status != null"> and t1.status = #{reqvo.status}</if>
        <if test="reqvo.keyWord != null  and reqvo.keyWord != ''"> and t1.content like concat('%', #{reqvo.keyWord}, '%')</if>
        <if test="reqvo.beginTime != null  and reqvo.finishTime != null">
            AND DATE(t1.start_time) BETWEEN #{reqvo.beginTime} AND #{reqvo.finishTime}
        </if>
        order by t1.top_time DESC
    </select>

    <select id="getCmPostMediaPage" parameterType="cn.metast.tuoke.module.community.controller.admin.cmPost.vo.CmPostPageReqVO" resultMap="CmPostResult">
        <include refid="cmPostVo"/>
             where t1.media != '' and t1.media is not  null and t1.deleted=0
        <if test="reqvo.userId != null  and reqvo.userId != ''"> and t1.user_id = #{reqvo.userId}</if>
            <if test="reqvo.topicId != null  and reqvo.topicId != ''"> and t1.topic_id = #{reqvo.topicId}</if>
            <if test="reqvo.postTop != null  and reqvo.postTop != ''"> and t1.post_top = #{reqvo.postTop}</if>
        <if test="reqvo.status != null  and reqvo.status != ''"> and t1.status = #{reqvo.status}</if>
        <if test="reqvo.keyWord != null  and reqvo.keyWord != ''"> and t1.content like concat('%', #{reqvo.keyWord}, '%')</if>
        <if test="reqvo.beginTime != null  and reqvo.finishTime != null">
            AND DATE(t1.start_time) BETWEEN #{reqvo.beginTime} AND #{reqvo.finishTime}
        </if>
        order by t1.create_time DESC
    </select>
    <select id="getCmPostCollectPage"  parameterType="cn.metast.tuoke.module.community.controller.admin.cmPost.vo.CmPostPageReqVO" resultMap="CmPostResult">
        <include refid="cmPostVo"/>
        where t1.deleted=0 and t1.id in (select post_id from cm_collect where user_id=#{reqvo.userId} and deleted=0)
        <if test="reqvo.topicId != null"> and t1.topic_id = #{reqvo.topicId}</if>
        <if test="reqvo.status != null"> and t1.status = #{reqvo.status}</if>
        order by t1.create_time DESC
    </select>

    <select id="getCmPostLikePage"  parameterType="cn.metast.tuoke.module.community.controller.admin.cmPost.vo.CmPostPageReqVO" resultMap="CmPostResult">
        <include refid="cmPostVo"/>
        where t1.deleted=0 and t1.id in (select post_id from cm_post_like where user_id=#{reqvo.userId} and deleted=0)
        <if test="reqvo.topicId != null"> and t1.topic_id = #{reqvo.topicId}</if>
        <if test="reqvo.status != null"> and t1.status = #{reqvo.status}</if>
        order by t1.create_time DESC
    </select>
</mapper>
